FROM golang:1.26-alpine

RUN apk add --no-cache git curl && \
    curl -sSfL https://raw.githubusercontent.com/air-verse/air/master/install.sh | sh -s -- -b /usr/local/bin

WORKDIR /workspace

ENV GOPRIVATE=github.com/devpablocristo/* \
    GONOSUMDB=github.com/devpablocristo/* \
    GONOPROXY=github.com/devpablocristo/* \
    GOPROXY=direct

COPY go.mod go.sum ./

WORKDIR /workspace/workshops/backend

RUN go mod download

COPY workshops/backend /workspace/workshops/backend
COPY pymes-core/shared/backend /workspace/pymes-core/shared/backend
COPY pkgs/go-pkg /workspace/pkgs/go-pkg

EXPOSE 8082

CMD ["air", "-c", ".air.toml"]
