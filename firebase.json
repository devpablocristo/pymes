{
  "hosting": {
    "public": "ui/dist",
    "ignore": [
      "firebase.generated.json",
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/v1/chat",
        "run": {
          "serviceId": "companion-dev",
          "region": "us-central1"
        }
      },
      {
        "source": "/v1/chat/**",
        "run": {
          "serviceId": "companion-dev",
          "region": "us-central1"
        }
      },
      {
        "source": "/v1/notifications",
        "run": {
          "serviceId": "companion-dev",
          "region": "us-central1"
        }
      },
      {
        "source": "/v1/workshops/**",
        "run": {
          "serviceId": "pymes-workshops",
          "region": "us-central1"
        }
      },
      {
        "source": "/v1/bike-shop/**",
        "run": {
          "serviceId": "pymes-workshops",
          "region": "us-central1"
        }
      },
      {
        "source": "/v1/auto-repair/**",
        "run": {
          "serviceId": "pymes-workshops",
          "region": "us-central1"
        }
      },
      {
        "source": "/v1/professionals/**",
        "run": {
          "serviceId": "pymes-professionals",
          "region": "us-central1"
        }
      },
      {
        "source": "/v1/teachers/**",
        "run": {
          "serviceId": "pymes-professionals",
          "region": "us-central1"
        }
      },
      {
        "source": "/v1/beauty/**",
        "run": {
          "serviceId": "pymes-beauty",
          "region": "us-central1"
        }
      },
      {
        "source": "/v1/restaurants/**",
        "run": {
          "serviceId": "pymes-restaurants",
          "region": "us-central1"
        }
      },
      {
        "source": "/v1/medical/**",
        "run": {
          "serviceId": "pymes-medical",
          "region": "us-central1"
        }
      },
      {
        "source": "/v1/**",
        "run": {
          "serviceId": "core",
          "region": "us-central1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
