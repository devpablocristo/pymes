FROM golang:1.26-alpine

RUN apk add --no-cache git curl postgresql-client && \
    curl -sSfL https://raw.githubusercontent.com/air-verse/air/master/install.sh | sh -s -- -b /usr/local/bin

WORKDIR /workspace

ENV GOPRIVATE=github.com/devpablocristo/* \
    GONOSUMDB=github.com/devpablocristo/* \
    GONOPROXY=github.com/devpablocristo/* \
    GOPROXY=direct

COPY go.mod go.sum /workspace/pymes/

WORKDIR /workspace/pymes/pymes-core/backend

RUN go mod download

COPY pymes-core/backend/docker-entrypoint-dev.sh /usr/local/bin/pymes-cp-backend-entrypoint.sh
RUN chmod +x /usr/local/bin/pymes-cp-backend-entrypoint.sh

COPY pymes-core/backend /workspace/pymes/pymes-core/backend
COPY pymes-core/shared/backend /workspace/pymes/pymes-core/shared/backend

EXPOSE 8080

ENTRYPOINT ["/usr/local/bin/pymes-cp-backend-entrypoint.sh"]
