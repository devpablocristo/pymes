FROM golang:1.26-alpine

RUN apk add --no-cache git curl postgresql-client && \
    curl -sSfL https://raw.githubusercontent.com/air-verse/air/master/install.sh | sh -s -- -b /usr/local/bin

WORKDIR /workspace

ENV GOPRIVATE=github.com/devpablocristo/* \
    GONOSUMDB=github.com/devpablocristo/* \
    GONOPROXY=github.com/devpablocristo/* \
    GOPROXY=direct

COPY pymes/go.mod pymes/go.sum /workspace/pymes/
# Local replace target for modules/scheduling/go (see pymes/go.mod replace
# directive). Remove once the module is published as v0.4.0.
COPY modules/scheduling/go /workspace/modules/scheduling/go

WORKDIR /workspace/pymes/pymes-core/backend

RUN go mod download

COPY pymes/pymes-core/backend/docker-entrypoint-dev.sh /usr/local/bin/pymes-cp-backend-entrypoint.sh
RUN chmod +x /usr/local/bin/pymes-cp-backend-entrypoint.sh

COPY pymes/pymes-core/backend /workspace/pymes/pymes-core/backend
COPY pymes/pymes-core/shared/backend /workspace/pymes/pymes-core/shared/backend

EXPOSE 8080

ENTRYPOINT ["/usr/local/bin/pymes-cp-backend-entrypoint.sh"]
