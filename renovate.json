{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "timezone": "America/Argentina/Buenos_Aires",
  "schedule": ["before 9am on monday"],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Group all @devpablocristo/* updates into a single PR — ecosystem coherence",
      "matchPackagePatterns": ["^@devpablocristo/"],
      "groupName": "devpablocristo ecosystem",
      "groupSlug": "devpablocristo",
      "schedule": ["at any time"],
      "automerge": false,
      "labels": ["dependencies", "ecosystem"]
    },
    {
      "description": "Auto-merge devDependencies patch + minor (safe churn)",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "description": "Hold majors for human review",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "major"]
    },
    {
      "description": "Go module: bump pymes/go.mod weekly",
      "matchManagers": ["gomod"],
      "schedule": ["before 9am on monday"]
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  }
}
