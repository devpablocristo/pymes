{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@devpablocristo/modules-calendar-board": ["../../modules/calendar/board/ts/src/index.ts"],
      "@devpablocristo/modules-calendar-board/styles.css": ["../../modules/calendar/board/ts/src/styles.css"],
      "@devpablocristo/modules-crud-ui/csv": ["../../modules/crud/ui/ts/src/csv.ts"],
      "@devpablocristo/modules-shell-sidebar": ["../../modules/sidebar/ts/src/index.ts"],
      "@devpablocristo/modules-shell-sidebar/styles.css": ["../../modules/sidebar/ts/src/styles.css"],
      "@devpablocristo/modules-ui-data-display/icons": ["../../modules/ui/data-display/ts/src/icons.tsx"],
      "@fullcalendar/core": ["./node_modules/@fullcalendar/core"],
      "@fullcalendar/daygrid": ["./node_modules/@fullcalendar/daygrid"],
      "@fullcalendar/interaction": ["./node_modules/@fullcalendar/interaction"],
      "@fullcalendar/react": ["./node_modules/@fullcalendar/react"],
      "@fullcalendar/timegrid": ["./node_modules/@fullcalendar/timegrid"],
      "react": ["./node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime.d.ts"],
      "react-dom": ["./node_modules/@types/react-dom/index.d.ts"],
      "react-dom/client": ["./node_modules/@types/react-dom/client.d.ts"]
    }
  },
  "include": [
    "src",
    "../../modules/calendar/board/ts/src",
    "../../modules/crud/ui/ts/src",
    "../../modules/sidebar/ts/src",
    "../../modules/ui/data-display/ts/src"
  ]
}
