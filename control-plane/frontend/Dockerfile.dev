FROM node:22-alpine

WORKDIR /workspace/control-plane/frontend

COPY control-plane/frontend/package.json control-plane/frontend/package-lock.json ./
RUN npm ci

COPY control-plane/frontend /workspace/control-plane/frontend
COPY pkgs/ts-pkg /workspace/pkgs/ts-pkg

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
