FROM golang:1.26-alpine

RUN apk add --no-cache git curl && \
    curl -sSfL https://raw.githubusercontent.com/air-verse/air/master/install.sh | sh -s -- -b /usr/local/bin

WORKDIR /workspace

ENV GOPRIVATE=github.com/devpablocristo/* \
    GONOSUMDB=github.com/devpablocristo/* \
    GONOPROXY=github.com/devpablocristo/* \
    GOPROXY=https://proxy.golang.org,direct

COPY pymes/go.mod pymes/go.sum /workspace/pymes/
COPY pymes/third_party/modules-scheduling-go /workspace/pymes/third_party/modules-scheduling-go
COPY pymes/third_party/core-calendar-ics-go /workspace/pymes/third_party/core-calendar-ics-go
COPY pymes/third_party/core-calendar-sync-google-go /workspace/pymes/third_party/core-calendar-sync-google-go
COPY core/scheduling/go /workspace/core/scheduling/go

WORKDIR /workspace/pymes/professionals/backend

RUN go mod download

COPY pymes/professionals/backend /workspace/pymes/professionals/backend
COPY pymes/pymes-core/shared/backend /workspace/pymes/pymes-core/shared/backend

EXPOSE 8081

CMD ["air", "-c", ".air.toml"]
