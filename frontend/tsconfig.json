{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@pymes/ts-pkg": ["../pkgs/ts-pkg/src"],
      "@pymes/ts-pkg/*": ["../pkgs/ts-pkg/src/*"]
    }
  },
  "include": ["src", "../pkgs/ts-pkg/src"]
}
