FROM python:3.12-slim

WORKDIR /workspace/pymes/ai
ENV PYTHONPATH=/workspace/pymes/ai:/workspace/core/ai/python/src

COPY pymes/ai/requirements.txt ./
COPY pymes/ai/requirements-dev.txt ./

RUN pip install --no-cache-dir -r requirements-dev.txt

COPY core/ai/python/src /workspace/core/ai/python/src
COPY pymes/ai/pyproject.toml ./
COPY pymes/ai/src/ ./src/
COPY pymes/ai/tests/ ./tests/

CMD ["uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
